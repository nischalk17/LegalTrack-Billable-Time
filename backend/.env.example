NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://billable:billable_pass@localhost:5432/billable_tracker

# JWT
JWT_SECRET=supersecretjwtkey_changeme_in_production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Email (Resend) — used for draft-bill-ready notifications
RESEND_API_KEY=
EMAIL_FROM=LegalTrack <billing@yourdomain.com>

# Internal auto-billing trigger — must match the secret the external
# scheduler (.github/workflows/auto-billing.yml) sends. Generate with:
#   openssl rand -base64 32
INTERNAL_CRON_SECRET=
